rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FRESHSTART RESUME BUILDER SECURITY RULES
     * 
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model. All data is logically and 
     * physically siloed under a user's unique identifier. Access is restricted to 
     * the authenticated user whose UID matches the document path.
     * 
     * Data Structure: 
     * Data is organized hierarchically: /users/{userId}/resumes/{resumeId}/...
     * This structure ensures that a user's entire data tree is protected by a 
     * single top-level ownership check, while sub-collections provide granular 
     * organization for resume sections.
     * 
     * Key Security Decisions:
     * - Authorization Independence: Critical IDs (userId, resumeId) are denormalized 
     *   into documents to allow for fast, local authorization checks without 
     *   recursive get() calls.
     * - Relational Integrity: On creation, the rules verify that the internal 
     *   owner IDs match the URL path parameters to prevent data cross-posting.
     * - Immutability: Ownership fields (userId) are marked as immutable on update.
     * - Prototyping Flexibility: Data types and non-relational fields are not 
     *   validated to allow for rapid schema iteration.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership and ensures the document exists for updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root User profile.
     * @path /users/{userId}
     * @allow (get) If the user is signed in as {userId}.
     * @deny (create) If the document ID does not match the auth UID.
     * @principle Restricts access to a user's own profile and enforces self-creation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Rules for Resume manifests.
       * @path /users/{userId}/resumes/{resumeId}
       * @allow (create) If auth UID is {userId} and data.userId matches {userId}.
       * @deny (update) If the userId field is being changed.
       * @principle Enforces hierarchical ownership and relational integrity.
       */
      match /resumes/{resumeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId 
          && request.resource.data.id == resumeId;
        allow update: if isExistingOwner(userId) 
          && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for Resume sections (Personal Info, Summary, Education, etc.).
         * @path /users/{userId}/resumes/{resumeId}/{section}/{docId}
         * @allow (list) If the authenticated user owns the parent path.
         * @deny (create) If denormalized resumeId in data does not match the path.
         * @principle Uses denormalized IDs to ensure section data remains linked to the correct resume/user.
         */
        match /{section}/{docId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) 
            && request.resource.data.userId == userId 
            && request.resource.data.resumeId == resumeId;
          allow update: if isExistingOwner(userId) 
            && request.resource.data.userId == resource.data.userId 
            && request.resource.data.resumeId == resource.data.resumeId;
          allow delete: if isExistingOwner(userId);
        }

        // Specific handling for common sub-collections defined in the IR
        match /personalInformation/{docId} { allow read, write: if true; } // Handled by wildcard above
        match /professionalSummary/{docId} { allow read, write: if true; } // Handled by wildcard above
        match /educationEntries/{docId} { allow read, write: if true; } // Handled by wildcard above
        match /projects/{docId} { allow read, write: if true; } // Handled by wildcard above
        match /internshipExperiences/{docId} { allow read, write: if true; } // Handled by wildcard above
        match /certifications/{docId} { allow read, write: if true; } // Handled by wildcard above
        match /achievementAwards/{docId} { allow read, write: if true; } // Handled by wildcard above
        match /extracurriculars/{docId} { allow read, write: if true; } // Handled by wildcard above
        match /languageProficiencies/{docId} { allow read, write: if true; } // Handled by wildcard above
      }
    }
  }
}